NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Mongo container creds. Used by docker-compose to seed the root user
# and by ensure-infra.ts to build MONGODB_URI.
MONGO_ROOT_USER=pokedex
MONGO_ROOT_PASSWORD=change-me-to-a-real-secret
# Host port rewritten by ensure-infra.ts if the default is taken.
MONGO_HOST_PORT=27017
# App connection string. ensure-infra.ts rewrites this if MONGO_HOST_PORT changes.
# authSource=admin because the root user lives in the admin db.
MONGODB_URI=mongodb://pokedex:change-me-to-a-real-secret@localhost:27017/pokedex?authSource=admin

JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=1h

ADMIN_NAME=admin
ADMIN_EMAIL=admin@pokedex.gg
ADMIN_USERNAME=pokeadmin
ADMIN_PASSWORD=change-me-min-8-chars

# Redis with AUTH (parity with prod). Host port rewritten by ensure-infra.ts.
REDIS_PASSWORD=change-me-to-a-real-secret
REDIS_HOST_PORT=6379
REDIS_URL=redis://:change-me-to-a-real-secret@localhost:6379

POKEAPI_BASE_URL=https://pokeapi.co/api/v2
POKEAPI_CACHE_TTL_SECONDS=3600

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

CORS_ORIGIN=http://localhost:5173
